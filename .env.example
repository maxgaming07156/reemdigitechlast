# Copy this file to .env (for local development) and add the same
# variables in your Vercel project settings (Project → Settings →
# Environment Variables) for production/preview deployments.

# --- Supabase ---
# Found in your Supabase project's Settings → API page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the client.
# Used by admin actions (lib/admin/*) via the service-role client.
SUPABASE_SERVICE_ROLE_KEY=

# Used by the Supabase CLI for migrations/local dev, not by the Next.js app directly.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# --- Site ---
# The deployed site URL, used for absolute URLs in metadata/OG tags.
# e.g. https://reemdigitech.com or your Vercel deployment URL.
NEXT_PUBLIC_SITE_URL=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFICATION_EMAIL=

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- AI Chatbot (Groq) ---
# Get your key from: https://console.groq.com/
GROQ_API_KEY=
